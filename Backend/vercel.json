{
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "private, no-store" },
                { "key": "CDN-Cache-Control", "value": "no-store" },
                { "key": "Vary", "value": "Origin" }
            ]
        }
    ]
}
